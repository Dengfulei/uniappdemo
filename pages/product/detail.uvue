  line-height: 22px;
}

.bottom-space {
  height: 92px;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 10px 16px 18px;
  background-color: #fffaf1;
  flex-direction: row;
  box-shadow: 0 -10px 24px rgba(36, 45, 41, 0.09);
}

.preview-button,
.cart-button {
  height: 46px;
  padding: 0;
