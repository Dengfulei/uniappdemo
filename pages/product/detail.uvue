  border-radius: 8px;
  color: #192421;
  background-color: #e7d5ba;
  font-size: 11px;
  font-weight: 700;
  line-height: 24px;
}

.sold {
  color: #9b8f7c;
  font-size: 12px;
}

.product-name {
  margin-top: 13px;
  color: #192421;
  font-size: 25px;
  line-height: 32px;
  font-weight: 700;
}

.summary {
  margin-top: 9px;
  color: #625d55;
  font-size: 14px;
  line-height: 22px;
}

.price-row {
  margin-top: 15px;
  flex-direction: row;
  align-items: center;
}

.price {
  color: #ba5336;
  font-size: 28px;
  font-weight: 700;
}

.original-price {
  margin-left: 9px;
  color: #aaa092;
  font-size: 13px;
}

.panel-title {
  color: #192421;
  font-size: 17px;
  font-weight: 700;
}

.spec-item {
  margin-top: 12px;
